LLM_PROVIDER=auto

# Anthropic (Claude)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# OpenAI-compatible (Qwen via DashScope / MaaS compatible API)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 推荐 flash 模型提速：qwen-flash / qwen-turbo（按你的平台实际模型名填写）
OPENAI_MODEL=qwen-flash
# 可选：分类与润色分别指定模型（默认继承 OPENAI_MODEL）
OPENAI_MODEL_CLASSIFY=qwen-flash
OPENAI_MODEL_POLISH=qwen-flash

# LLM 超时（秒）
LLM_TIMEOUT_CLASSIFY=45
LLM_TIMEOUT_POLISH=180
# 并行分类线程数（新文章多时可提速，建议 2-4）
LLM_CLASSIFY_WORKERS=3
# 是否启用整合后中文润色（false 可再省 1 次 LLM 调用）
LLM_ENABLE_POLISH=true

# Notifications (Bark homepage Key, NOT device token)
BARK_KEY=
BARK_SERVER=https://api.day.app

# Digest push limits (consolidated output)
DIGEST_MAX_BUSINESS=5
DIGEST_MAX_TECH=8
DIGEST_MIN_IMPORTANCE=3
DIGEST_MAX_POOL=60
