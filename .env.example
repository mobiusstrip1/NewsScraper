LLM_PROVIDER=auto

# Anthropic (Claude)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# OpenAI-compatible (Qwen via DashScope compatible API)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus

# Notifications
# Fill Bark push Key (homepage), NOT iOS device token.
BARK_KEY=
# Optional self-hosted Bark server, default: https://api.day.app
BARK_SERVER=https://api.day.app

# Digest push limits (consolidated output)
DIGEST_MAX_BUSINESS=5
DIGEST_MAX_TECH=8
DIGEST_MIN_IMPORTANCE=3
DIGEST_MAX_POOL=60

